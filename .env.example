# ─────────────────────────────────────────────────────────────
# Copy this file to `.env.local` for local dev (it is gitignored).
# In Vercel, add the same two variables under
# Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Your monday.com API token (SECRET — never commit the real value).
# Get it in monday.com: avatar (bottom-left) → Developers → My Access Tokens.
MONDAY_API_TOKEN=your-monday-api-token-here

# The "Sunbull Web Leads" board id (not secret).
MONDAY_BOARD_ID=18416212537
